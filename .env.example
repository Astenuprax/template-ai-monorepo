# Copy to .env and fill in. All values are optional for a local run:
# without ANTHROPIC_API_KEY the demo falls back to a direct MCP round-trip (no LLM call).

# Anthropic API key for the live agent run.
ANTHROPIC_API_KEY=

# Override the agent model (any pydantic-ai model string).
AGENT_MODEL=anthropic:claude-sonnet-4-6
