// Dev Container for template-ai-monorepo (uv-workspace AI/agentic monorepo).
// Author: Phillip Anderson | Integrate-IT Australia
// JSONC: comments permitted. See repo-structure-standard and repo-hygiene
// for layout/hygiene; governance-standards for coding/output contracts.
{
  "name": "template-ai-monorepo",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {
    // Install the uv package/project manager via the official Astral feature.
    "ghcr.io/astral-sh/uv:1": {}
  },
  // Resolve the full uv workspace (platform-core agent + example-mcp-server)
  // once the container is created.
  "postCreateCommand": "uv sync --all-packages",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pyright",
        "charliermarsh.ruff"
      ],
      "settings": {
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
        "python.terminal.activateEnvInCurrentTerminal": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true,
          "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "explicit",
            "source.organizeImports.ruff": "explicit"
          }
        }
      }
    }
  },
  "remoteUser": "vscode"
}
